<body>

<div id="page-wrapper">
	<div id='div__alert' class="text-align: center"></div>
<div class="login-page-body" data-page-type="login">
	<div class="login-page-main">
		<div class="login-page-box">
			<div class="login-page-box-logos">
				<a class="login-page-box-logo-link" href="http://www.netsuite.com/portal/home.shtml?noredirect=T" tabindex="-1">
					<img class="login-page-box-logo login-page-box-logo--ns"
						src="/authentication/ui/loginpage/assets/logo/NetSuite-logo-mobius.svg" alt="Oracle NetSuite" />
				</a>
			</div>
			<h2 class="login-page-box-title">Log In</h2>


			<form method="post" id="login-form" class="login-page-form" data-validate data-cookie-prefill data-reset-rememberme>
				<input type="hidden" name="jsenabled" value="F">

					<input type="hidden" name="redirect" value="/app/suiteapp/devframework/xml/datafileexport.nl?recordtype=advancedpdftemplate&amp;amp;name=template&amp;amp;id=435">
					<input type="hidden" name="c" value="6962009_SB2">

				<div class="login-page-form-field">
					<input type="text" name="email" id="email" required data-validate-on-blur
						placeholder="Email address"/>
					<label for="email">Email address</label>
					<div class="validation-message">
						<p>
							<img src="/uiredwood/img/message/error.svg" alt="" />
							<span>Valid email is required: name@company.com</span>
						</p>
					</div>
				</div>

				<div class="login-page-form-field">
					<input type="password" name="password" id="password" autocomplete="off" required data-validate-on-blur
						placeholder="Password"/>
					<label for="password">Password</label>
					<div class="validation-message">
						<p>
							<img src="/uiredwood/img/message/error.svg" alt="" />
							<span>Password is required</span>
						</p>
					</div>
				</div>

				<div class="login-page-form-checkbox">
					<input type="checkbox" name="rememberme" id="rememberme" class="login-checkbox"/>
					<label for="rememberme">Remember Me</label>
				</div>

				<button class="login-page-form-submit" type="submit" name="submitButton" id="login-submit">
					<svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
						<path d="M11.9982 4C14.2074 4 15.9982 5.79086 15.9982 8V11H7.99823V8C7.99823 5.79086 9.78909 4 11.9982 4ZM17.9982 11V8C17.9982 4.68629 15.3119 2 11.9982 2C8.68452 2 5.99823 4.68629 5.99823 8V11H1.99823V22H21.9982V11H17.9982ZM3.99823 13H19.9982V20H3.99823V13Z"></path>
					</svg>
					<span>Log In</span>
				</button>


				<a href="/app/login/preparepwdreset.nl?email=&"
					class="login-page-form-forgot">Forgot your password?</a>

			</form>

			<div class="login-page-box-footer">
				By clicking on the Log In button, you understand and agree to
				<a href="https://www.oracle.com/us/legal/terms/index.html">Oracle Terms of Use</a>
				and
				<a href="https://www.oracle.com/us/legal/privacy/privacy-policy/index.html">Oracle Privacy Policy</a>
			</div>
		</div>

		<div class="login-page-footer">
			<a class="link" href="https://www.oracle.com/legal/copyright.html">© Oracle</a>
			<span class="sep">|</span>
			<a class="link" href="http://www.netsuite.com/portal/assets/pdf/oracle-terms-use-netsuite-support-portal.pdf">Oracle Terms of Use for NetSuite Support Portal</a>
		</div>
	</div>
</div>
